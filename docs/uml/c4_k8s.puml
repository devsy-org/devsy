@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam linetype ortho
skinparam nodesep 200
skinparam ranksep 150
scale 1920x1080

HIDE_STEREOTYPE()
LAYOUT_TOP_DOWN()

title Component diagram for Devsy with the Kubernetes provider

Person(user, "Devsy User", "CLI or Desktop")
System(prov, "Kubernetes Provider", "Devsy provider, kubectl-based")
Component(ide, "IDE", "Local IDE")
Component(ctx, "Context", "Config, working dir, kubeconfig")
Component(env, "Local Env", "Shell vars, git credentials")

System_Boundary(cluster, "Kubernetes Cluster") {
  System(controlPlane, "kube-apiserver", "Manages the cluster")
  System_Boundary(ns, "devsy namespace") {
    Container_Boundary(ws, "Workspace Pod") {
      Component(init, "Init Container", "PVC + agent delivery")
      Component(runner, "Dev Container", "User's devcontainer image")
      Component(agent, "Container Agent", "devsy agent container daemon")
      Component(ssh, "SSH Server", "Tunnelled stdio")
      ContainerDb(dir, "Workspace PVC", "PersistentVolumeClaim", "")
    }
  }
}

BiRel_Right(user, prov, "devsy workspace up ...")
BiRel(prov, controlPlane, "kubectl exec / apply")
BiRel(controlPlane, agent, "")
BiRel_Left(agent, ssh, "Tunnelled stdio")
Rel(agent, runner, "lifecycle hooks")
Rel(init, runner, "delivers agent binary")
BiRel(user, ide, "SSH port forwarding")
Rel_Up(user, ctx, "")
Rel_Left(user, env, "")
@enduml
