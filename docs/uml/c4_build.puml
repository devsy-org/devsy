@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam linetype ortho
skinparam nodesep 100
skinparam ranksep 250
scale 1920x1080

LAYOUT_TOP_DOWN()
HIDE_STEREOTYPE()

title Component Diagram for the Devsy build process

Person(user, "Devsy User", "CLI or Desktop")
Component(reg, "Container Registry", "Push target + remote cache")
Component(buildkit, "BuildKit / Dockerless", "BuildKit for remote, Dockerless for in-cluster")
Component(ctx, "Build Context", "Driver, registry cache, features, options")
Component(merged, "Merged Devcontainer Config", "Compiled config + Dockerfile")

Boundary(repo, "Git repo") {
  Component(bctx, "Workspace source", "Source code, dotfiles")
  Component(df, "Dockerfile", "")

  Boundary(cluster, "Dev Container Spec") {
    Component(dc, ".devcontainer.json", "Dev environment definition")
    Component(fa, "Feature A", "docker-in-docker, language tools, ...")
    Component(fb, "Feature B", "git, secrets, ...")
  }
}

Rel(repo, user, "")
Rel(dc, user, "")
Rel(fa, user, "merged into")
Rel(fb, user, "merged into")
Rel_Right(ctx, user, "")
Rel(user, merged, "compile devcontainer config")
Rel(merged, buildkit, "build")
Rel(buildkit, reg, "push image + cache layers")
@enduml
