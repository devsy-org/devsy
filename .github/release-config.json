{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "label": "autorelease: stable",
  "release-label": "autorelease: stable-tagged",
  "packages": {
    ".": {
      "release-type": "go",
      "prerelease": false,
      "versioning": "default",
      "bump-minor-pre-major": true,
      "component": "devsy",
      "changelog-path": "CHANGELOG-stable.md",
      "include-component-in-tag": false,
      "include-v-in-tag": true
    }
  }
}
