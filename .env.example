# Environment variables for running E2E tests locally.
# Copy this file to .env and fill in the values.

# --- Required for private-repo tests ---

# GitHub username (repository owner or personal account)
GH_USERNAME=

# GitHub personal access token or GitHub App token with repo access
GH_ACCESS_TOKEN=

# Credential username for git authentication.
# Use "x-access-token" for GitHub App tokens, or your GH_USERNAME for PATs.
GH_CREDENTIAL_USERNAME=x-access-token

# --- Required for Kubernetes-based tests ---

# Path to kubeconfig for the kind cluster used by E2E tests.
# dotenv does NOT expand shell variables like ${HOME} or ~.
# Replace with your actual absolute path.
KUBECONFIG=/home/youruser/.kube/config

# --- Optional ---

# Custom Docker socket path (e.g. for podman: npipe:////./pipe/podman-machine-default)
# DOCKER_HOST=

# Override the agent binary download URL. Set automatically by the test
# framework on non-Linux platforms; only set this if you need a custom build.
# DEVSY_AGENT_URL=
