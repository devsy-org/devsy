#!/usr/bin/env bash
# Wrapper script for running DevPod inside Flatpak

export ELECTRON_IS_DEV=0

# Determine if running inside Flatpak
if [ -f "/.flatpak-info" ]; then
  # Sync the devpod binary to a host-accessible location
  DEVPOD_HOME="${HOME}/.local/share/devpod"
  mkdir -p "${DEVPOD_HOME}"

  if [ -f /app/bin/devpod ]; then
    cp /app/bin/devpod "${DEVPOD_HOME}/devpod"
    chmod +x "${DEVPOD_HOME}/devpod"
  fi
fi

exec /app/devpod/devpod-desktop "$@"
