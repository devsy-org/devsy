  "AGENT_INJECT_TIMEOUT": { "value": "20" },
  "REGISTRY_CACHE": { "value": "" },
  "EXIT_AFTER_TIMEOUT": { "value": "true" },
  "SSH_CONFIG_PATH": { "value": "" },
  "SSH_CONFIG_INCLUDE_PATH": { "value": "" }
}
JSON
        ;;
      use|set-options|create|delete)
        echo ""
        ;;
      *)
        echo ""
        ;;
    esac
    ;;
  status)
    # Return per-workspace status based on workspace ID
    case "$SUB" in
      dev-env)
        echo '{"state": "Stopped"}'
        ;;
      *)
        echo '{"state": "Running"}'
        ;;
    esac
    ;;
  version)
    echo "v0.1.0-test"
    ;;
  ssh)
    exec /bin/sh
    ;;
  up)
    echo "Resolving source..."
    sleep 0.1
    echo "Pulling image..."
    sleep 0.1
    echo "Starting workspace..."
    sleep 0.1
    echo "Workspace ready."
    exit 0
    ;;
  stop)
    echo "Stopping workspace..."
    sleep 0.1
    echo "Workspace stopped."
    exit 0
    ;;
  delete)
    echo "Deleting workspace..."
    sleep 0.1
    echo "Workspace deleted."
    exit 0
    ;;
  upgrade)
    echo "Already up to date."
    exit 0
    ;;
  *)
    echo "mock-devpod: unknown command '$CMD'" >&2
    exit 1
    ;;
esac
