{
  "branches": [
    { "name": "main", "prerelease": "rc" },
    { "name": "release", "prerelease": false }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      { "successComment": false, "failTitle": false }
    ]
  ]
}
