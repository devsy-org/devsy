{
  "name": "images-devsy-sh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate": "tsx scripts/validate-catalog.ts src/catalog.json",
    "build": "npm run validate && vite build && cp src/catalog.json dist/catalog.json",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-check --tsconfig tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.19.20",
    "jsdom": "^29.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
