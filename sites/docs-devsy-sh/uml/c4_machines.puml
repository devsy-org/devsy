@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam linetype ortho
skinparam nodesep 150
skinparam ranksep 150
scale 1920x1080

HIDE_STEREOTYPE()
LAYOUT_TOP_DOWN()

title Component diagram for Devsy with machine providers

Person(user, "Devsy User", "CLI or Desktop")
System(prov, "Machine Provider", "aws, gcp, azure, ssh, ...")
Component(ide, "IDE", "Local IDE")
Component(ctx, "Context", "Config, working dir")
Component(env, "Local Env", "Shell vars, git/docker credentials")

System_Boundary(cluster, "Virtual Machine") {
  System(machineAgent, "Machine Agent", "devsy agent workspace ...")
  System(dockerd, "Docker daemon", "Manages workspace containers")
  Container_Boundary(ws, "Workspace") {
    Component(runner, "Dev Container", "User's devcontainer image")
    Component(cAgent, "Container Agent", "devsy agent container daemon")
    Component(ssh, "SSH Server", "Tunnelled stdio")
    ContainerDb(dir, "Workspace Volume", "Volume", "Source + cache")
  }
}

BiRel(user, prov, "devsy workspace up ...")
BiRel(prov, machineAgent, "provider-specific secure tunnel")
Rel(machineAgent, dockerd, "docker run / exec")
Rel(dockerd, ws, "")
Rel(cAgent, ssh, "")
Rel(cAgent, runner, "lifecycle hooks")
BiRel_Right(user, ide, "SSH port forwarding")
Rel(ctx, user, "")
Rel(env, user, "")
BiRel(machineAgent, cAgent, "gRPC tunnel over stdio")
@enduml
