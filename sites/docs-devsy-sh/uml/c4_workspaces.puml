@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam linetype ortho
skinparam nodesep 150
skinparam ranksep 150
scale 1920x1080

HIDE_STEREOTYPE()
LAYOUT_TOP_DOWN()

title Component diagram for Devsy workspaces

Person(user, "Devsy User", "CLI or Desktop")
System(prov, "Devsy Provider", "docker / kubernetes / custom driver")
Component(ide, "IDE", "VS Code, JetBrains, Fleet, Jupyter, ...")
Component(ctx, "Context", "Active context, working dir, config")
Component(env, "Local Env", "Shell vars, git/docker credentials")
Component(dc, ".devcontainer.json", "Dev container spec + features")
Component(git, "Git repo", "Project source")

System_Boundary(cluster, "Machine or Cluster") {
  System(machineAgent, "Machine Agent", "devsy agent workspace ...")
  Container_Boundary(ws, "Workspace") {
    Component(runner, "Dev Container", "User's devcontainer image")
    Component(cAgent, "Container Agent", "devsy agent container ...")
    Component(ssh, "SSH Server", "Tunnelled into the container")
    ContainerDb(dir, "Workspace Volume", "Volume", "Source + build cache")
  }
}

BiRel(user, prov, "devsy workspace up ...")
BiRel(prov, machineAgent, "provider tunnel")
BiRel(machineAgent, cAgent, "gRPC tunnel over stdio")
BiRel_Left(cAgent, ssh, "stdio")
Rel(cAgent, runner, "lifecycle hooks")
BiRel_Left(user, ide, "SSH port forwarding")
Rel(ctx, user, "")
Rel(env, user, "")
Rel(git, user, "")
Rel(dc, user, "")
@enduml
