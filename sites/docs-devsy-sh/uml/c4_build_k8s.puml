@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include <material/common>
!include <material/sync>

HIDE_STEREOTYPE()
LAYOUT_TOP_DOWN()

title Devsy build pipeline on Kubernetes (dockerless)

Person(user, "Devsy User", "CLI or Desktop")
System(prov, "Kubernetes Provider", "Devsy provider")

System_Boundary(host, "Kubernetes Cluster") {
    System(controlPlane, "kube-apiserver", "Manages the cluster")

    System_Boundary(devsyns, "devsy namespace") {

        Container_Boundary(buildPod, "Build Pod") {
            ContainerDb(ctxVol, "Build Context", "Volume", "Workspace source + Dockerfile")
            ContainerDb(cache, "Layer Cache", "Volume", "Local image cache")
            Container(dockerless, "Dockerless Builder", "ghcr.io/devsy-org/dockerless", "Builds OCI image in userspace (no daemon)")
        }
    }
}

System_Boundary(registry, "Container Registry") {
    System(registryCache, "Image Repository", "Final workspace images")
    System(cacheRepo, "Registry Cache", "BuildKit / dockerless cache layers")
}

Rel(user, prov, "devsy workspace up ...")
Rel(prov, controlPlane, "kubectl apply")
Rel(controlPlane, dockerless, "creates Build Pod")
Rel(user, registry, "devsy workspace build ...")
Rel(dockerless, registry, "push image + cache")
Rel(registry, dockerless, "pull cached layers")
@enduml
